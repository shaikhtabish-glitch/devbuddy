# DevBuddy — Environment Configuration
#
# Copy this file to .env and add your OpenRouter API key.
# .env is git-ignored — never commit real keys.

OPENROUTER_API_KEY=sk-or-your-key-here

# Default model (change to any OpenRouter model string)
DEVBUDDY_MODEL=openai/gpt-4o-mini

# Optional: alt model for swap tests
# DEVBUDDY_MODEL_ALT=anthropic/claude-3.5-sonnet
